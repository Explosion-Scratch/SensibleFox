<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>SensibleFox</title>
    <welcome file="welcome.html" mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>
    <options customize="never" allow-external-scripts="no" rootVolumeOnly="true"/>
    <volume-check>
        <allowed-os-versions>
            <os-version min="11.0"/>
        </allowed-os-versions>
    </volume-check>
    <choices-outline>
        <line choice="default">
            <line choice="{{PKG_IDENTIFIER}}"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="{{PKG_IDENTIFIER}}" visible="false">
        <pkg-ref id="{{PKG_IDENTIFIER}}"/>
    </choice>
    <pkg-ref id="{{PKG_IDENTIFIER}}" version="{{PKG_VERSION}}" onConclusion="none">component.pkg</pkg-ref>
</installer-gui-script>
